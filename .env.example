# Copy to .env and fill in your values

# ── Database ────────────────────────────────────────────────
# Choose your database backend: "sqlite" (default) or "postgres"
DB_TYPE=sqlite

# SQLite — path to the database file (default: ~/.proxyhub/proxyhub.db)
# DB_PATH=/var/lib/proxyhub/proxyhub.db

# PostgreSQL — only used when DB_TYPE=postgres
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=proxymanager
# DB_USER=postgres
DB_PASSWORD=proxymanager123

# ── Ports ───────────────────────────────────────────────────
PROXY_PORT=8080       # Port devices connect to
API_PORT=3000         # REST API port
FRONTEND_PORT=8888    # Dashboard port

# ── Authentication ───────────────────────────────────────────
# Require device API key for proxy connections
REQUIRE_AUTH=false

# Admin password for the web dashboard.
# If set, overrides the password configured during the onboarding wizard.
# Useful for Docker / env-only deployments or emergency resets.
# Leave blank to use the password set during onboarding.
ADMIN_PASSWORD=

# JWT signing secret. Change to a long random string in production.
JWT_SECRET=change-me-to-a-long-random-secret

# ── Auto Sync ────────────────────────────────────────────────
# How often (in minutes) to automatically check proxies and refresh
# their geo metadata. Set to 0 to disable background sync.
SYNC_INTERVAL_MINUTES=30
